{
  "name": "geo-workstation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev:api": "pnpm --filter @geo-workstation/shared build && pnpm --filter @geo-workstation/api start:dev",
    "dev:web": "pnpm --filter @geo-workstation/shared build && pnpm --filter @geo-workstation/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "prisma:validate": "pnpm --filter @geo-workstation/api prisma:validate",
    "prisma:generate": "pnpm --filter @geo-workstation/api prisma:generate",
    "prisma:migrate": "pnpm --filter @geo-workstation/api prisma:migrate",
    "prisma:seed": "pnpm --filter @geo-workstation/api prisma:seed",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.0",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
