{
  "name": "geo-workstation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev:api": "pnpm --filter @geo-workstation/shared build && pnpm --filter @geo-workstation/api start:dev",
    "dev:web": "pnpm --filter @geo-workstation/shared build && pnpm --filter @geo-workstation/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "prisma:validate": "pnpm --filter @geo-workstation/api prisma:validate",
    "prisma:generate": "pnpm --filter @geo-workstation/api prisma:generate",
    "prisma:migrate": "pnpm --filter @geo-workstation/api prisma:migrate",
    "prisma:seed": "pnpm --filter @geo-workstation/api prisma:seed",
    "test:api": "pnpm --filter @geo-workstation/api test:api",
    "test:geo-prompts": "pnpm --filter @geo-workstation/api test:geo-prompts",
    "test:geo-expansion": "pnpm --filter @geo-workstation/api test:geo-expansion",
    "test:geo-knowledge": "pnpm --filter @geo-workstation/api test:geo-knowledge",
    "test:geo-knowledge-files": "pnpm --filter @geo-workstation/api test:geo-knowledge-files",
    "test:geo-instructions": "pnpm --filter @geo-workstation/api test:geo-instructions",
    "test:geo-content": "pnpm --filter @geo-workstation/api test:geo-content",
    "test:model-inclusion": "pnpm --filter @geo-workstation/api test:model-inclusion",
    "test:geo-reports": "pnpm --filter @geo-workstation/api test:geo-reports",
    "test:geo-analysis": "pnpm --filter @geo-workstation/api test:geo-analysis",
    "test:ai-provider": "pnpm --filter @geo-workstation/api test:ai-provider",
    "test:auth": "pnpm --filter @geo-workstation/api test:auth",
    "test:web-framework": "pnpm --filter @geo-workstation/web test:phase3a",
    "test:web-dashboard": "pnpm --filter @geo-workstation/web test:dashboard",
    "test:web-geo-prompts": "pnpm --filter @geo-workstation/web test:geo-prompts",
    "test:web-expansion": "pnpm --filter @geo-workstation/web test:expansion",
    "test:web-knowledge": "pnpm --filter @geo-workstation/web test:knowledge",
    "test:web-instructions": "pnpm --filter @geo-workstation/web test:instructions",
    "test:web-content": "pnpm --filter @geo-workstation/web test:content",
    "test:web-model-inclusion": "pnpm --filter @geo-workstation/web test:model-inclusion",
    "test:web-reports": "pnpm --filter @geo-workstation/web test:reports",
    "test:web-mvp": "pnpm --filter @geo-workstation/web test:mvp",
    "test:web-geo-analysis": "pnpm --filter @geo-workstation/web test:geo-analysis",
    "test:web-auth": "pnpm --filter @geo-workstation/web test:auth",
    "test:web-settings": "pnpm --filter @geo-workstation/web test:settings",
    "test:web-help": "pnpm --filter @geo-workstation/web test:help",
    "test:prisma": "pnpm --filter @geo-workstation/api test:prisma",
    "smoke:api": "node scripts/smoke-test-api.mjs",
    "check:internal-mvp": "node scripts/check-internal-mvp.mjs",
    "check:deployment": "node scripts/check-deployment-readiness.mjs",
    "check:self-use": "node scripts/check-self-use-ready.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.0",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
