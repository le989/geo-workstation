{
  "name": "@geo-workstation/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "pnpm --filter @geo-workstation/shared build && vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test:phase3a": "node scripts/check-phase-3a.mjs",
    "test:dashboard": "node scripts/check-phase-3b.mjs",
    "test:geo-prompts": "node scripts/check-phase-3c.mjs",
    "test:expansion": "node scripts/check-phase-3d.mjs",
    "test:knowledge": "node scripts/check-phase-3e.mjs",
    "test:instructions": "node scripts/check-phase-3f.mjs",
    "test:content": "node scripts/check-phase-3g.mjs",
    "test:model-inclusion": "node scripts/check-phase-3h.mjs",
    "test:reports": "node scripts/check-phase-3i.mjs",
    "test:mvp": "node scripts/check-frontend-mvp.mjs",
    "test:geo-analysis": "node scripts/check-phase-4a.mjs",
    "test:auth": "node scripts/check-phase-4d.mjs",
    "test:users": "node scripts/check-users.mjs",
    "test:settings": "node scripts/check-phase-general1-settings.mjs",
    "test:usage": "node scripts/check-token-usage.mjs",
    "test:ai-provider": "node scripts/check-ai-provider-safety.mjs",
    "test:logs-viewer": "node scripts/check-logs-viewer-ui.mjs",
    "test:help": "node scripts/check-phase-help1.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@geo-workstation/shared": "workspace:*",
    "element-plus": "^2.11.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.8"
  }
}
