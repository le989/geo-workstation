# Same-origin reverse proxy mode:
# Leave VITE_API_BASE_URL empty when Nginx serves the web app and proxies /api and /health to the API.
VITE_API_BASE_URL=

# Separate API origin mode:
# Set a full origin when the web app and API are served from different hosts.
# VITE_API_BASE_URL=http://your-domain.example.com

VITE_APP_ENV_LABEL=Production / Mock
