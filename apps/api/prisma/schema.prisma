generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  platform_admin
  company_admin
  operator
  admin
  geo_operator
  content_editor
  viewer
}

enum UserStatus {
  active
  disabled
}

enum CompanyType {
  internal
  customer
}

enum CompanyStatus {
  active
  disabled
}

enum ProductLineStatus {
  active
  disabled
}

enum DepartmentStatus {
  active
  inactive
}

enum MembershipRole {
  platform_admin
  company_admin
  operator
  viewer
}

enum MembershipStatus {
  active
  disabled
}

enum Visibility {
  PRIVATE
  COMPANY
  PLATFORM
}

enum TaskStatus {
  pending
  running
  succeeded
  failed
  cancelled
}

enum GeoPromptType {
  base
  distilled
  brand
  scene
}

enum UserIntent {
  selection
  purchase
  manufacturer_recommendation
  domestic_alternative
  comparison
  troubleshooting
  application_solution
  brand_verification
}

enum ExpansionMode {
  rule
  ai
}

enum ParseStatus {
  pending
  parsing
  succeeded
  failed
}

enum KnowledgeMaterialType {
  product_material
  aftersales_material
  company_trust_material
  content_reference_material
  internal_process_material
  customer_case_material
}

enum KnowledgeReviewStatus {
  pending
  approved
  disabled
}

enum KnowledgeTrustLevel {
  high
  medium
  low
}

enum AftersalesAnswerStatus {
  answered
  no_reliable_source
  failed
}

enum AftersalesFeedbackStatus {
  none
}

enum RecordMethod {
  manual
  api
  import
}

enum AiCallStatus {
  pending
  succeeded
  failed
}

model User {
  id                    String                 @id @default(cuid())
  name                  String
  email                 String                 @unique
  passwordHash          String?                @map("password_hash")
  role                  UserRole               @default(viewer)
  status                UserStatus             @default(active)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  memberships           Membership[]
  createdProjectProfiles ProjectProfile[]       @relation("ProjectProfileCreatedBy")
  updatedProjectProfiles ProjectProfile[]       @relation("ProjectProfileUpdatedBy")
  geoAnalysisTasks      GeoAnalysisTask[]       @relation("GeoAnalysisTaskCreatedBy")
  updatedGeoAnalysisTasks GeoAnalysisTask[]     @relation("GeoAnalysisTaskUpdatedBy")
  geoPrompts            GeoPrompt[]             @relation("GeoPromptCreatedBy")
  updatedGeoPrompts     GeoPrompt[]             @relation("GeoPromptUpdatedBy")
  expansionJobs         ExpansionJob[]          @relation("ExpansionJobCreatedBy")
  updatedExpansionJobs  ExpansionJob[]          @relation("ExpansionJobUpdatedBy")
  knowledgeBases        KnowledgeBase[]         @relation("KnowledgeBaseCreatedBy")
  updatedKnowledgeBases KnowledgeBase[]         @relation("KnowledgeBaseUpdatedBy")
  knowledgeFiles        KnowledgeFile[]         @relation("KnowledgeFileCreatedBy")
  updatedKnowledgeFiles KnowledgeFile[]         @relation("KnowledgeFileUpdatedBy")
  instructionTemplates  InstructionTemplate[]   @relation("InstructionTemplateCreatedBy")
  updatedInstructionTemplates InstructionTemplate[] @relation("InstructionTemplateUpdatedBy")
  contentTasks          ContentTask[]           @relation("ContentTaskCreatedBy")
  updatedContentTasks   ContentTask[]           @relation("ContentTaskUpdatedBy")
  modelInclusionRecords ModelInclusionRecord[]  @relation("ModelInclusionRecordCreatedBy")
  updatedModelInclusionRecords ModelInclusionRecord[] @relation("ModelInclusionRecordUpdatedBy")
  aiCallLogs            AiCallLog[]             @relation("AiCallLogCreatedBy")
  aiUsageRecords        AiUsageRecord[]         @relation("AiUsageRecordUser")
  operationLogs         OperationLog[]          @relation("OperationLogUser")
  aftersalesQuestionRecords AftersalesQuestionRecord[] @relation("AftersalesQuestionRecordUser")

  @@map("users")
}

model Company {
  id                    String                 @id @default(cuid())
  name                  String
  code                  String                 @unique
  type                  CompanyType            @default(internal)
  status                CompanyStatus          @default(active)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  productLines          ProductLine[]
  departments           Department[]
  departmentModulePermissions DepartmentModulePermission[]
  memberships           Membership[]
  projectProfiles       ProjectProfile[]
  geoAnalysisTasks      GeoAnalysisTask[]
  geoPrompts            GeoPrompt[]
  expansionJobs         ExpansionJob[]
  knowledgeBases        KnowledgeBase[]
  knowledgeFiles        KnowledgeFile[]
  knowledgeChunks       KnowledgeChunk[]
  instructionTemplates  InstructionTemplate[]
  contentTasks          ContentTask[]
  contentItems          ContentItem[]
  modelInclusionRecords ModelInclusionRecord[]
  aiCallLogs            AiCallLog[]
  aiUsageRecords        AiUsageRecord[]
  operationLogs         OperationLog[]
  aftersalesQuestionRecords AftersalesQuestionRecord[]

  @@map("companies")
}

model ProductLine {
  id                    String                 @id @default(cuid())
  companyId             String                 @map("company_id")
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name                  String
  code                  String
  status                ProductLineStatus      @default(active)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  geoAnalysisTasks      GeoAnalysisTask[]
  geoPrompts            GeoPrompt[]
  knowledgeBases        KnowledgeBase[]
  knowledgeChunks       KnowledgeChunk[]
  contentTasks          ContentTask[]
  modelInclusionRecords ModelInclusionRecord[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("product_lines")
}

model Department {
  id                String                       @id @default(cuid())
  companyId         String                       @map("company_id")
  company           Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name              String
  code              String
  status            DepartmentStatus             @default(active)
  memberships       Membership[]
  modulePermissions DepartmentModulePermission[]
  aiUsageRecords    AiUsageRecord[]
  operationLogs     OperationLog[]
  aftersalesQuestionRecords AftersalesQuestionRecord[]
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
  @@map("departments")
}

model DepartmentModulePermission {
  id           String     @id @default(cuid())
  companyId    String     @map("company_id")
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  moduleKey    String     @map("module_key")
  canAccess    Boolean    @default(false) @map("can_access")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([departmentId, moduleKey])
  @@index([companyId])
  @@index([moduleKey])
  @@map("department_module_permissions")
}

model Membership {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String           @map("company_id")
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String?       @map("department_id")
  department Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  role      MembershipRole   @default(operator)
  status    MembershipStatus @default(active)
  isDefault Boolean          @default(false) @map("is_default")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([departmentId])
  @@index([role])
  @@map("memberships")
}

model ProjectProfile {
  id              String   @id @default(cuid())
  companyId       String?  @map("company_id")
  company         Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  projectName     String   @map("project_name")
  companyName     String?  @map("company_name")
  brandName       String?  @map("brand_name")
  websiteUrl      String?  @map("website_url")
  industry        String?
  mainProducts    Json?    @map("main_products")
  targetCustomers String?  @map("target_customers")
  positioning     String?
  tone            String?
  forbiddenClaims Json?    @map("forbidden_claims")
  targetModels    Json?    @map("target_models")
  notes           String?
  createdById     String?  @map("created_by")
  createdBy       User?    @relation("ProjectProfileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?  @map("updated_by")
  updatedBy       User?    @relation("ProjectProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([createdById])
  @@index([updatedById])
  @@map("project_profiles")
}

model GeoAnalysisTask {
  id                String           @id @default(cuid())
  companyId         String?          @map("company_id")
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name              String
  brandName         String           @map("brand_name")
  websiteUrl        String?          @map("website_url")
  productLine       String?          @map("product_line")
  productLineId     String?          @map("product_line_id")
  productLineRef    ProductLine?     @relation(fields: [productLineId], references: [id], onDelete: SetNull)
  targetModels      Json?            @map("target_models")
  status            TaskStatus       @default(pending)
  summary           Json?
  contentGaps       Json?            @map("content_gaps")
  knowledgeGaps     Json?            @map("knowledge_gaps")
  promptSuggestions Json?            @map("prompt_suggestions")
  createdById       String           @map("created_by")
  createdBy         User             @relation("GeoAnalysisTaskCreatedBy", fields: [createdById], references: [id])
  updatedById       String?          @map("updated_by")
  updatedBy         User?            @relation("GeoAnalysisTaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  modelResults      GeoModelResult[]

  @@index([companyId])
  @@index([createdById])
  @@index([updatedById])
  @@index([brandName])
  @@index([productLine])
  @@index([productLineId])
  @@index([status])
  @@map("geo_analysis_tasks")
}

model GeoModelResult {
  id                String          @id @default(cuid())
  analysisTaskId    String          @map("analysis_task_id")
  analysisTask      GeoAnalysisTask @relation(fields: [analysisTaskId], references: [id], onDelete: Cascade)
  promptText        String          @map("prompt_text")
  model             String
  brandMentioned    Boolean         @default(false) @map("brand_mentioned")
  brandRecommended  Boolean         @default(false) @map("brand_recommended")
  rankingPosition   Int?            @map("ranking_position")
  citedOfficialSite Boolean         @default(false) @map("cited_official_site")
  answerSummary     String?         @map("answer_summary")
  competitors       Json?
  rawAnswer         String?         @map("raw_answer")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([analysisTaskId])
  @@index([model])
  @@map("geo_model_results")
}

model KnowledgeBase {
  id           String           @id @default(cuid())
  companyId    String?          @map("company_id")
  company      Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name         String
  productLine  String?          @map("product_line")
  productLineId String?         @map("product_line_id")
  productLineRef ProductLine?   @relation(fields: [productLineId], references: [id], onDelete: SetNull)
  description  String?
  status       String            @default("active")
  visibility   Visibility        @default(COMPANY)
  createdById  String           @map("created_by")
  createdBy    User             @relation("KnowledgeBaseCreatedBy", fields: [createdById], references: [id])
  updatedById  String?          @map("updated_by")
  updatedBy    User?            @relation("KnowledgeBaseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")
  files        KnowledgeFile[]
  chunks       KnowledgeChunk[]
  contentTasks ContentTask[]

  @@index([companyId])
  @@index([createdById])
  @@index([updatedById])
  @@index([productLine])
  @@index([productLineId])
  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
  @@map("knowledge_bases")
}

model KnowledgeFile {
  id              String           @id @default(cuid())
  companyId       String?          @map("company_id")
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  knowledgeBaseId String           @map("knowledge_base_id")
  knowledgeBase   KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  title           String?
  fileName        String           @map("file_name")
  fileType        String           @map("file_type")
  fileSize        Int?             @map("file_size")
  storagePath     String?          @map("storage_path")
  sourceType      String           @default("upload") @map("source_type")
  materialType    KnowledgeMaterialType @default(content_reference_material) @map("material_type")
  applicableModules Json?          @map("applicable_modules")
  sourceDescription String?        @map("source_description")
  trustLevel      KnowledgeTrustLevel @default(medium) @map("trust_level")
  reviewStatus    KnowledgeReviewStatus @default(pending) @map("review_status")
  allowedDepartmentIds Json?       @map("allowed_department_ids")
  parseStatus     ParseStatus      @default(pending) @map("parse_status")
  errorMessage    String?          @map("error_message")
  createdById     String           @map("created_by")
  createdBy       User             @relation("KnowledgeFileCreatedBy", fields: [createdById], references: [id])
  updatedById     String?          @map("updated_by")
  updatedBy       User?            @relation("KnowledgeFileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  chunks          KnowledgeChunk[]

  @@index([companyId])
  @@index([knowledgeBaseId])
  @@index([createdById])
  @@index([updatedById])
  @@index([parseStatus])
  @@index([materialType])
  @@index([trustLevel])
  @@index([reviewStatus])
  @@index([deletedAt])
  @@map("knowledge_files")
}

model KnowledgeChunk {
  id              String         @id @default(cuid())
  companyId       String?        @map("company_id")
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  knowledgeBaseId String         @map("knowledge_base_id")
  knowledgeBase   KnowledgeBase  @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  fileId          String?        @map("file_id")
  file            KnowledgeFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  title           String
  content         String
  sourceType      String         @map("source_type")
  productLine     String?        @map("product_line")
  productLineId   String?        @map("product_line_id")
  productLineRef  ProductLine?   @relation(fields: [productLineId], references: [id], onDelete: SetNull)
  materialType    String?        @map("material_type")
  tags            Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  @@index([companyId])
  @@index([knowledgeBaseId])
  @@index([fileId])
  @@index([productLine])
  @@index([productLineId])
  @@index([materialType])
  @@index([deletedAt])
  @@map("knowledge_chunks")
}

model GeoPrompt {
  id                   String                 @id @default(cuid())
  companyId            String?                @map("company_id")
  company              Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  type                 GeoPromptType          @map("type")
  baseWord             String?                @map("base_word")
  promptText           String                 @map("prompt_text")
  productLine          String?                @map("product_line")
  productLineId        String?                @map("product_line_id")
  productLineRef       ProductLine?           @relation(fields: [productLineId], references: [id], onDelete: SetNull)
  scenario             String?
  userIntent           UserIntent             @default(selection) @map("user_intent")
  priority             Int                    @default(3)
  targetModels         Json?                  @map("target_models")
  source               String?
  trackEnabled         Boolean                @default(false) @map("track_enabled")
  latestCoverageStatus String?                @map("latest_coverage_status")
  visibility           Visibility             @default(COMPANY)
  createdById          String                 @map("created_by")
  createdBy            User                   @relation("GeoPromptCreatedBy", fields: [createdById], references: [id])
  updatedById          String?                @map("updated_by")
  updatedBy            User?                  @relation("GeoPromptUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  deletedAt            DateTime?              @map("deleted_at")
  expansionCandidates  ExpansionCandidate[]   @relation("SavedPrompt")
  contentItems         ContentItem[]
  inclusionRecords     ModelInclusionRecord[]

  @@index([companyId])
  @@index([createdById])
  @@index([updatedById])
  @@index([type])
  @@index([promptText])
  @@index([productLine])
  @@index([productLineId])
  @@index([userIntent])
  @@index([trackEnabled])
  @@index([visibility])
  @@index([deletedAt])
  @@map("geo_prompts")
}

model ExpansionJob {
  id           String               @id @default(cuid())
  companyId    String?              @map("company_id")
  company      Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  mode         ExpansionMode
  promptType   GeoPromptType         @map("prompt_type")
  inputPayload Json                 @map("input_payload")
  provider     String?
  model        String?
  status       TaskStatus            @default(pending)
  createdById  String               @map("created_by")
  createdBy    User                 @relation("ExpansionJobCreatedBy", fields: [createdById], references: [id])
  updatedById  String?              @map("updated_by")
  updatedBy    User?                @relation("ExpansionJobUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  candidates   ExpansionCandidate[]

  @@index([companyId])
  @@index([createdById])
  @@index([updatedById])
  @@index([mode])
  @@index([promptType])
  @@index([status])
  @@map("expansion_jobs")
}

model ExpansionCandidate {
  id                     String        @id @default(cuid())
  jobId                  String        @map("job_id")
  job                    ExpansionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  baseWord               String?       @map("base_word")
  promptText             String        @map("prompt_text")
  userIntent             UserIntent?   @map("user_intent")
  priority               Int           @default(3)
  recommendedContentType String?       @map("recommended_content_type")
  selected               Boolean       @default(false)
  savedPromptId          String?       @map("saved_prompt_id")
  savedPrompt            GeoPrompt?    @relation("SavedPrompt", fields: [savedPromptId], references: [id], onDelete: SetNull)
  createdAt              DateTime      @default(now()) @map("created_at")

  @@index([jobId])
  @@index([savedPromptId])
  @@index([selected])
  @@map("expansion_candidates")
}

model InstructionTemplate {
  id               String         @id @default(cuid())
  companyId        String?        @map("company_id")
  company          Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name             String
  instructionType  String         @map("instruction_type")
  contentType      String         @map("content_type")
  targetPromptType GeoPromptType? @map("target_prompt_type")
  targetModel      String?        @map("target_model")
  instruction      String
  outputFormat     String?        @map("output_format")
  qualityRules     String?        @map("quality_rules")
  forbiddenRules   String?        @map("forbidden_rules")
  visibility       Visibility     @default(COMPANY)
  createdById      String         @map("created_by")
  createdBy        User           @relation("InstructionTemplateCreatedBy", fields: [createdById], references: [id])
  updatedById      String?        @map("updated_by")
  updatedBy        User?          @relation("InstructionTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")
  contentTasks     ContentTask[]

  @@index([companyId])
  @@index([createdById])
  @@index([updatedById])
  @@index([instructionType])
  @@index([contentType])
  @@index([targetPromptType])
  @@index([visibility])
  @@index([deletedAt])
  @@map("instruction_templates")
}

model ContentTask {
  id                    String               @id @default(cuid())
  companyId             String?              @map("company_id")
  company               Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name                  String
  productLine           String?              @map("product_line")
  productLineId         String?              @map("product_line_id")
  productLineRef        ProductLine?         @relation(fields: [productLineId], references: [id], onDelete: SetNull)
  knowledgeBaseId       String?              @map("knowledge_base_id")
  knowledgeBase         KnowledgeBase?       @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)
  instructionTemplateId String?              @map("instruction_template_id")
  instructionTemplate   InstructionTemplate? @relation(fields: [instructionTemplateId], references: [id], onDelete: SetNull)
  generationType        String               @map("generation_type")
  targetModel           String?              @map("target_model")
  status                TaskStatus           @default(pending)
  provider              String?
  model                 String?
  createdById           String               @map("created_by")
  createdBy             User                 @relation("ContentTaskCreatedBy", fields: [createdById], references: [id])
  updatedById           String?              @map("updated_by")
  updatedBy             User?                @relation("ContentTaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  contentItems          ContentItem[]

  @@index([companyId])
  @@index([createdById])
  @@index([updatedById])
  @@index([productLine])
  @@index([productLineId])
  @@index([knowledgeBaseId])
  @@index([instructionTemplateId])
  @@index([status])
  @@map("content_tasks")
}

model ContentItem {
  id                      String       @id @default(cuid())
  companyId               String?      @map("company_id")
  company                 Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  taskId                  String       @map("task_id")
  task                    ContentTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  geoPromptId             String?      @map("geo_prompt_id")
  geoPrompt               GeoPrompt?   @relation(fields: [geoPromptId], references: [id], onDelete: SetNull)
  title                   String
  body                    String
  geoOptimizationPoints   Json?        @map("geo_optimization_points")
  suggestedPublishChannel String?      @map("suggested_publish_channel")
  status                  String       @default("draft")
  errorMessage            String?      @map("error_message")
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")
  deletedAt               DateTime?    @map("deleted_at")

  @@index([companyId])
  @@index([taskId])
  @@index([geoPromptId])
  @@index([status])
  @@index([deletedAt])
  @@map("content_items")
}

model ModelInclusionRecord {
  id                 String       @id @default(cuid())
  companyId          String?      @map("company_id")
  company            Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  productLineId      String?      @map("product_line_id")
  productLineRef     ProductLine? @relation(fields: [productLineId], references: [id], onDelete: SetNull)
  geoPromptId        String       @map("geo_prompt_id")
  geoPrompt          GeoPrompt    @relation(fields: [geoPromptId], references: [id], onDelete: Cascade)
  model              String
  platform           String?
  entryPoint         String?      @map("entry_point")
  detectionMethod    String?      @map("detection_method")
  deviceType         String?      @map("device_type")
  isWebSearchEnabled Boolean      @default(false) @map("is_web_search_enabled")
  isLoggedIn         Boolean      @default(false) @map("is_logged_in")
  checkedAt          DateTime     @default(now()) @map("checked_at")
  brandMentioned     Boolean      @default(false) @map("brand_mentioned")
  brandRecommended   Boolean      @default(false) @map("brand_recommended")
  rankingPosition    Int?         @map("ranking_position")
  citedOfficialSite  Boolean      @default(false) @map("cited_official_site")
  citedContentAsset  Boolean      @default(false) @map("cited_content_asset")
  competitorMentioned Boolean     @default(false) @map("competitor_mentioned")
  hitLevel           String?      @map("hit_level")
  answerSummary      String?      @map("answer_summary")
  rawAnswer          String?      @map("raw_answer") @db.Text
  citations          Json?
  searchResults      Json?        @map("search_results")
  screenshotPath     String?      @map("screenshot_path")
  errorMessage       String?      @map("error_message") @db.Text
  competitors        Json?
  recordMethod       RecordMethod @default(manual) @map("record_method")
  createdById        String       @map("created_by")
  createdBy          User         @relation("ModelInclusionRecordCreatedBy", fields: [createdById], references: [id])
  updatedById        String?      @map("updated_by")
  updatedBy          User?        @relation("ModelInclusionRecordUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now()) @map("created_at")

  @@index([companyId])
  @@index([productLineId])
  @@index([geoPromptId])
  @@index([createdById])
  @@index([updatedById])
  @@index([model])
  @@index([platform])
  @@index([entryPoint])
  @@index([detectionMethod])
  @@index([deviceType])
  @@index([checkedAt])
  @@index([brandMentioned])
  @@index([brandRecommended])
  @@index([isWebSearchEnabled])
  @@index([isLoggedIn])
  @@index([citedContentAsset])
  @@index([competitorMentioned])
  @@index([hitLevel])
  @@map("model_inclusion_records")
}

model AiCallLog {
  id           String       @id @default(cuid())
  companyId    String?      @map("company_id")
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdById  String?      @map("created_by")
  createdBy    User?        @relation("AiCallLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  provider     String
  model        String
  purpose      String
  relatedType  String?      @map("related_type")
  relatedId    String?      @map("related_id")
  tokenInput   Int?         @map("token_input")
  tokenOutput  Int?         @map("token_output")
  costEstimate Decimal?     @map("cost_estimate") @db.Decimal(12, 6)
  status       AiCallStatus @default(pending)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([companyId])
  @@index([createdById])
  @@index([provider])
  @@index([model])
  @@index([purpose])
  @@index([relatedType, relatedId])
  @@index([status])
  @@map("ai_call_logs")
}

model AiUsageRecord {
  id               String      @id @default(cuid())
  companyId        String?     @map("company_id")
  company          Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId           String?     @map("user_id")
  user             User?       @relation("AiUsageRecordUser", fields: [userId], references: [id], onDelete: SetNull)
  departmentId     String?     @map("department_id")
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  moduleKey        String      @map("module_key")
  action           String
  provider         String
  model            String?
  isMock           Boolean     @default(false) @map("is_mock")
  promptTokens     Int         @default(0) @map("prompt_tokens")
  completionTokens Int         @default(0) @map("completion_tokens")
  totalTokens      Int         @default(0) @map("total_tokens")
  requestCount     Int         @default(1) @map("request_count")
  success          Boolean     @default(true)
  errorMessage     String?     @map("error_message")
  metadata         Json?
  createdAt        DateTime    @default(now()) @map("created_at")
  aftersalesQuestionRecords AftersalesQuestionRecord[]

  @@index([companyId])
  @@index([userId])
  @@index([departmentId])
  @@index([moduleKey])
  @@index([action])
  @@index([provider])
  @@index([isMock])
  @@index([success])
  @@index([createdAt])
  @@map("ai_usage_records")
}

model AftersalesQuestionRecord {
  id                String                    @id @default(cuid())
  companyId         String                    @map("company_id")
  company           Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId            String                    @map("user_id")
  user              User                      @relation("AftersalesQuestionRecordUser", fields: [userId], references: [id], onDelete: Restrict)
  departmentId      String?                   @map("department_id")
  department        Department?               @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  question          String                    @db.Text
  answer            String                    @db.Text
  answerStatus      AftersalesAnswerStatus    @default(no_reliable_source) @map("answer_status")
  citedSources      Json                      @default("[]") @map("cited_sources")
  usedMaterialTypes Json                      @default("[]") @map("used_material_types")
  isAnswered        Boolean                   @default(false) @map("is_answered")
  hasReliableSource Boolean                   @default(false) @map("has_reliable_source")
  isMock            Boolean                   @default(true) @map("is_mock")
  aiUsageRecordId   String?                   @map("ai_usage_record_id")
  aiUsageRecord     AiUsageRecord?            @relation(fields: [aiUsageRecordId], references: [id], onDelete: SetNull)
  feedbackStatus    AftersalesFeedbackStatus  @default(none) @map("feedback_status")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([userId])
  @@index([departmentId])
  @@index([answerStatus])
  @@index([hasReliableSource])
  @@index([isAnswered])
  @@index([aiUsageRecordId])
  @@index([createdAt])
  @@map("aftersales_question_records")
}

model OperationLog {
  id           String      @id @default(cuid())
  companyId    String?     @map("company_id")
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId       String?     @map("user_id")
  user         User?       @relation("OperationLogUser", fields: [userId], references: [id], onDelete: SetNull)
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  moduleKey    String      @map("module_key")
  action       String
  targetType   String      @map("target_type")
  targetId     String?     @map("target_id")
  targetTitle  String?     @map("target_title")
  success      Boolean     @default(true)
  errorMessage String?     @map("error_message")
  ip           String?
  userAgent    String?     @map("user_agent")
  metadata     Json?
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([companyId])
  @@index([userId])
  @@index([departmentId])
  @@index([moduleKey])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([success])
  @@index([createdAt])
  @@map("operation_logs")
}
