{
  "name": "@geo-workstation/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "build": "pnpm --filter @geo-workstation/shared build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:seed": "prisma db seed --config prisma.config.ts",
    "test:api": "vitest run test/api-infrastructure.spec.ts test/geo-prompts.service.spec.ts test/geo-prompts.controller.spec.ts test/geo-expansion.service.spec.ts test/geo-expansion.controller.spec.ts test/knowledge-bases.service.spec.ts test/knowledge.controller.spec.ts test/knowledge-file-parser.service.spec.ts test/knowledge-files.service.spec.ts test/knowledge-files.controller.spec.ts test/instruction-templates.service.spec.ts test/instruction-templates.controller.spec.ts",
    "test:geo-prompts": "vitest run test/geo-prompts.service.spec.ts test/geo-prompts.controller.spec.ts",
    "test:geo-expansion": "vitest run test/geo-expansion.service.spec.ts test/geo-expansion.controller.spec.ts",
    "test:geo-knowledge": "vitest run test/knowledge-bases.service.spec.ts test/knowledge.controller.spec.ts",
    "test:geo-knowledge-files": "vitest run test/knowledge-file-parser.service.spec.ts test/knowledge-files.service.spec.ts test/knowledge-files.controller.spec.ts",
    "test:geo-instructions": "vitest run test/instruction-templates.service.spec.ts test/instruction-templates.controller.spec.ts",
    "test:prisma": "vitest run test/prisma-schema.spec.ts"
  },
  "dependencies": {
    "@geo-workstation/shared": "workspace:*",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "vitest": "^4.1.5"
  }
}
